<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sportsmeet.mapper.DepartmentMapper">
    <select id="findAll" resultType="com.sportsmeet.entity.Department">
        SELECT id, name, create_time FROM department ORDER BY id
    </select>
    <select id="findById" resultType="com.sportsmeet.entity.Department">
        SELECT id, name, create_time FROM department WHERE id = #{id}
    </select>
</mapper>